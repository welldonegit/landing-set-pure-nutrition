# Зразок змінних оточення. Скопіюйте у .env і заповніть локально.
# .env у git не потрапляє (див. .gitignore) — справжні значення лишаються на машині.

# Порт, на якому слухає backend. Vite проксує /api саме сюди.
PORT=3001

# Секрети (токен бота, ключі оплати) з'являться тут на кроці інтеграції.
# У клієнтський код вони не потрапляють ніколи: усе, що збирає Vite,
# видно будь-кому у вкладці «Мережа» браузера.

# Зразок змінних оточення. Скопіюйте у .env і заповніть локально.
# .env у git не потрапляє (див. .gitignore) — справжні значення лишаються на машині.

# Порт, на якому слухає backend.
# У dev Vite проксує /api саме сюди; у production Express віддає ще й dist/.
PORT=3001

# development | production
# У production Express обслуговує зібраний фронтенд із dist/.
NODE_ENV=production

# Telegram: куди надсилати заявки.
# Токен бота бере @BotFather; chat_id — це id групи або особистого чату.
# Обидва значення лишаються ТІЛЬКИ на сервері: у клієнтський бандл вони не
# потрапляють ніколи, бо все, що збирає Vite, видно у вкладці «Мережа».
# Поки ці змінні порожні, сервер приймає заявку й чесно відповідає
# 503 TELEGRAM_NOT_CONFIGURED, а не вдає успіх.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Адреса Bot API. Змінюють лише в тестах, щоб не ходити в мережу.
# TELEGRAM_API_BASE=https://api.telegram.org

# KeyCRM: створення замовлення через API.
# Токен бере адміністратор у налаштуваннях KeyCRM. Лишається ТІЛЬКИ на сервері.
# KEYCRM_SOURCE_ID — числовий id джерела замовлень (напр. «Лендінг»).
KEYCRM_API_TOKEN=
KEYCRM_API_BASE=https://openapi.keycrm.app
KEYCRM_SOURCE_ID=

# Нова Пошта: довідники міст і відділень/поштоматів для форми.
# Ключ бере кабінет НП. Лишається ТІЛЬКИ на сервері: фронтенд ходить
# на власні /api/nova-poshta/*, а не в НП напряму.
NOVA_POSHTA_API_KEY=
NOVA_POSHTA_API_BASE=https://api.novaposhta.ua/v2.0/json/
